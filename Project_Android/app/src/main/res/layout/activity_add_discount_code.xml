<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/discount_surface"
    android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Quay lại"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    android:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/tvDiscountFormTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Thêm mã giảm giá"
                    android:textColor="@color/brand_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnAdminAvatar"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_circle_avatar"
                    android:contentDescription="Tài khoản quản trị"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="@android:color/white" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Quản lý khuyến mãi"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chi tiết chương trình"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="34dp"
                android:letterSpacing="0.1"
                android:text="TÊN CHƯƠNG TRÌNH"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtPromotionName"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_create_order_input"
                android:hint="Ví dụ: Ưu đãi mùa Thu 2024"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:paddingHorizontal="18dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/hint_color_emphasis"
                android:textSize="17sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="26dp"
                android:letterSpacing="0.1"
                android:text="MÃ GIẢM GIÁ"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtDiscountCode"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_create_order_input"
                android:hint="AUTUMN24"
                android:inputType="textCapCharacters"
                android:maxLines="1"
                android:paddingHorizontal="18dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/hint_color_emphasis"
                android:textSize="17sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_discount_form_panel"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:text="LOẠI GIẢM GIÁ"
                    android:textColor="@color/text_label"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_discount_type_track"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/btnPercentType"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_bottom_nav_active"
                        android:gravity="center"
                        android:text="Phần trăm"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnFixedType"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Số tiền"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="116dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_discount_form_panel"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:text="GIÁ TRỊ"
                    android:textColor="@color/text_label"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtDiscountValue"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="0"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="@color/brand_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvValueUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:gravity="center_vertical"
                        android:text="%"
                        android:textColor="@color/brand_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@drawable/bg_discount_value_line" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="28dp"
                android:letterSpacing="0.1"
                android:text="ĐƠN TỐI THIỂU (VND)"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtMinimumOrder"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_create_order_input"
                android:hint="500,000"
                android:inputType="numberDecimal"
                android:maxLines="1"
                android:paddingHorizontal="18dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="17sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="26dp"
                android:letterSpacing="0.1"
                android:text="GIẢM TỐI ĐA (VND)"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtMaximumDiscount"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_create_order_input"
                android:hint="200.000"
                android:inputType="number"
                android:maxLines="1"
                android:paddingHorizontal="18dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="17sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="26dp"
                android:letterSpacing="0.1"
                android:text="SỐ LƯỢNG SỬ DỤNG"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtUsageLimit"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_create_order_input"
                android:hint="100"
                android:inputType="number"
                android:maxLines="1"
                android:paddingHorizontal="18dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="17sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_discount_form_panel"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_calendar_simple"
                        android:tint="@color/accent_magenta" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Thời gian áp dụng"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:letterSpacing="0.1"
                    android:text="TỪ NGÀY"
                    android:textColor="@color/text_label"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtStartDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_create_order_input"
                    android:clickable="true"
                    android:drawableEnd="@drawable/ic_calendar_simple"
                    android:drawablePadding="12dp"
                    android:focusable="false"
                    android:hint="dd/mm/yyyy"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:letterSpacing="0.1"
                    android:text="ĐẾN NGÀY"
                    android:textColor="@color/text_label"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtEndDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_create_order_input"
                    android:clickable="true"
                    android:drawableEnd="@drawable/ic_calendar_simple"
                    android:drawablePadding="12dp"
                    android:focusable="false"
                    android:hint="dd/mm/yyyy"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnSaveDiscount"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_button_create_customer"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSaveDiscountLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lưu mã giảm giá"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
</ScrollView>
