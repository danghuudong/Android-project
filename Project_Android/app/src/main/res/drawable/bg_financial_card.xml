<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#F3F0FA" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item android:width="3dp" android:gravity="start">
        <shape>
            <solid android:color="@color/accent_magenta" />
            <corners android:topLeftRadius="14dp" android:bottomLeftRadius="14dp" />
        </shape>
    </item>
</layer-list>